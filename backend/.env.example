# ── Supabase (uncomment + fill to switch auth from stub to real accounts) ──
# Project URL and PUBLISHABLE key only — never put the service_role/secret
# key here or in any client. Find both in: Supabase dashboard → Settings → API.
#
# SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
# SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# (legacy keys also accepted:)
# SUPABASE_ANON_KEY=eyJ...

# Where magic-link / OAuth redirects land (the frontend URL)
FRONTEND_ORIGIN=http://localhost:5173

# Optional: Postgres instead of SQLite
# DATABASE_URL=postgresql://user:pass@host:5432/stammtisch
